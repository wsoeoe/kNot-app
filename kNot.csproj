<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
    <Nullable>disable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>knot</AssemblyName>
    <RootNamespace>kNot</RootNamespace>
    <Version>1.0.0</Version>
    <Company>kNot</Company>
    <Product>kNot - обход замедлений сервисов</Product>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="data\dpi\WinDivert.dll" />
    <EmbeddedResource Include="data\dpi\WinDivert64.sys" />
    <EmbeddedResource Include="data\dpi\quic_initial_www_google_com.bin" />
    <EmbeddedResource Include="data\dpi\quic_initial_dbankcloud_ru.bin" />
    <EmbeddedResource Include="data\dpi\tls_clienthello_www_google_com.bin" />
  </ItemGroup>

</Project>
